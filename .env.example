# WGS Extract CLI Environment Configuration
# Copy this file to .env.local and adjust paths for your local machine

# Path to the reference genome folder or direct FASTA
# WGSE_REF="/Users/username/src/WGSExtract/reference"
# WGSE_REF_FASTA="/Users/username/src/WGSExtract/reference/hs38DH.fa.gz"

# Default input files for testing
# WGSE_INPUT="/Users/username/src/genomes/example.cram"
# WGSE_INPUT_VCF="/Users/username/src/genomes/example.vcf.gz"

# Mappability map for CNV analysis (Delly)
# WGSE_MAP="/Users/username/src/WGSExtract/reference/hs38DH.map.fa.gz"

# VEP cache path
# WGSE_VEP_CACHE="/Users/username/.vep"

# DeepVariant checkpoint path
# WGSE_DV_CHECKPOINT="reference/models/deepvariant/WGS/deepvariant.wgs.ckpt"

# Tool Paths (if not in system PATH)
# WGSE_HAPLOGREP_PATH="/opt/homebrew/Caskroom/miniconda/base/envs/wgse/bin/haplogrep"
# WGSE_YLEAF_ENV_PATH="/opt/homebrew/Caskroom/miniconda/base/envs/yleaf_env"
# WGSE_WGSE_ENV_PATH="/opt/homebrew/Caskroom/miniconda/base/envs/wgse"

# Output directory for analysis results
WGSE_OUTDIR="out/analysis_results"

# Global defaults
# WGSE_THREADS=8
# WGSE_MEMORY=2G
# WGSE_DEBUG=0
